---
import { formatCompactNumber, getSparklinePath } from "@/lib/format";
import { getOssProjects } from "@/lib/oss";

const projects = await getOssProjects();
---

<section>
  <div class="divide-y divide-border">
    {
      projects.map((project) => (
        <a
          class="group flex items-center justify-between gap-6 py-4 transition-colors hover:text-primary"
          href={project.url}
          rel="noopener noreferrer"
          target="_blank"
        >
          <span class="flex min-w-0 items-center gap-2">
            <span class="font-medium text-base">{project.name}</span>
            {project.acquired && (
              <span class="shrink-0 rounded-full border border-border px-2 py-0.5 text-xs font-medium text-foreground/50">
                Acquired
              </span>
            )}
          </span>

          <div class="flex items-center gap-4 text-sm text-foreground/50">
            {project.points.length >= 2 && (
              <svg
                aria-hidden="true"
                class="h-5 w-[4.5rem] shrink-0 text-foreground/40 transition-colors group-hover:text-primary"
                fill="none"
                viewBox="0 0 84 24"
              >
                <path
                  d={getSparklinePath(project.points)}
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-width="2"
                />
              </svg>
            )}

            <span
              class="inline-flex w-16 shrink-0 items-center gap-1.5 tabular-nums"
              title={`${project.downloads.toLocaleString()} downloads (last year)`}
            >
              <svg
                aria-hidden="true"
                class="size-4 shrink-0"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M12 3v12m0 0 4-4m-4 4-4-4M4 19h16" />
              </svg>
              {formatCompactNumber(project.downloads)}
            </span>

            <span
              class="inline-flex w-14 shrink-0 items-center gap-1.5 tabular-nums"
              title={`${project.stars.toLocaleString()} stars`}
            >
              <svg
                aria-hidden="true"
                class="size-4 shrink-0"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 6.91-1.01L12 2z" />
              </svg>
              {formatCompactNumber(project.stars)}
            </span>
          </div>
        </a>
      ))
    }
  </div>
</section>
